{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "simple-calendar-app-web",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "npm run sync:events && npx expo start --web --port 8090"],
      "port": 8090
    },
    {
      "name": "simple-calendar-app-web-vajrayana",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "EXPO_PUBLIC_APP_CLIENT=vajrayana npm run web"],
      "port": 8081
    }
  ]
}
